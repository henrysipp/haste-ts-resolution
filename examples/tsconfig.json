{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "plugins": [
      {
        "name": "haste-ts-plugin",
        "rootDir": "./src",
        "excludeDirs": ["app"],
        "platforms": ["ios", "android", "native", "web"],
        "indexAsPackage": true
      }
    ]
  },
  "include": ["src"]
}
